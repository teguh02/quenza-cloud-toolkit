# ==============================================================
# Quenza Cloud Toolkit - Environment Configuration (EXAMPLE)
# Copy this file to `.env` and fill in the values.
# ==============================================================

# --- Authentication ---------------------------------------------------------
# Bcrypt hash of your Master Password.
# Generate it by running:  python generate_hash.py
# Example value (do NOT reuse): $2b$12$abcdefghijklmnopqrstuv...
MASTER_PASSWORD_HASH=

# --- Session ----------------------------------------------------------------
# Secret key used to sign the session cookie. Use a long random string.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret

# Session lifetime in seconds (default: 8 hours).
SESSION_MAX_AGE=28800

# --- Database ---------------------------------------------------------------
# SQLite connection string (default stores quenza.db in project root).
DATABASE_URL=sqlite:///./quenza.db

# --- Backup engine (Phase 4) ------------------------------------------------
# Directory used to stage archives and as the default Local destination root.
BACKUP_WORK_DIR=./backups
# Paths to database dump tools. Leave as the command name if they are on PATH.
MYSQLDUMP_PATH=mysqldump
PG_DUMP_PATH=pg_dump

# --- Secrets encryption -----------------------------------------------------
# Fernet key used to encrypt sensitive destination config (e.g. Google Drive
# refresh tokens). Generate one with:  python generate_key.py
ENCRYPTION_KEY=

# --- Google Drive OAuth (Phase 4.5) -----------------------------------------
# Create an OAuth client (type: Web application) in Google Cloud Console,
# enable the Google Drive API, and add the redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/destinations/gdrive/callback

# --- Application ------------------------------------------------------------
# Set to "false" in production to send the session cookie over HTTPS only.
DEBUG=true
